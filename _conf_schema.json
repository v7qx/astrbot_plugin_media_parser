{
    "parsers": {
        "description": "解析器与输出模式",
        "type": "object",
        "hint": "关闭=不解析该平台；仅文本=只发送标题/作者/简介等文本；仅富媒体=只发送图片/视频",
        "items": {
            "bilibili": {
                "description": "B站",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "仅文本"
            },
            "douyin": {
                "description": "抖音",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            },
            "tiktok": {
                "description": "TikTok",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            },
            "kuaishou": {
                "description": "快手",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            },
            "weibo": {
                "description": "微博",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            },
            "xiaohongshu": {
                "description": "小红书",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            },
            "xianyu": {
                "description": "闲鱼",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "关闭"
            },
            "toutiao": {
                "description": "今日头条",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "关闭"
            },
            "xiaoheihe": {
                "description": "小黑盒",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "关闭"
            },
            "twitter": {
                "description": "Twitter/X",
                "type": "string",
                "options": [
                    "关闭",
                    "全部发送",
                    "仅文本",
                    "仅富媒体"
                ],
                "default": "全部发送"
            }
        }
    },
    "trigger": {
        "description": "触发设置",
        "type": "object",
        "items": {
            "auto_parse": {
                "description": "自动解析链接",
                "type": "bool",
                "default": false
            },
            "keywords": {
                "description": "手动触发关键词",
                "type": "list",
                "hint": "关闭自动解析时，消息含关键词才触发",
                "default": [
                    "视频解析",
                    "解析视频"
                ]
            },
            "reply_trigger": {
                "description": "回复触发解析",
                "type": "bool",
                "hint": "引用含链接的消息并附关键词即可触发解析",
                "default": false
            }
        }
    },
    "message": {
        "description": "消息与展示",
        "type": "object",
        "items": {
            "auto_pack": {
                "description": "打包为消息集合",
                "type": "bool",
                "hint": "媒体较多时建议启用；将会把图文视频按独立转发节点分批发送",
                "default": true
            },
            "forward_chunk_size": {
                "description": "合并转发分批数量",
                "type": "int",
                "hint": "开启打包时，单个合并转发节点包含的最大媒体数量；0 = 不限制数量",
                "default": 0
            },
            "direct_image_batch_size": {
                "description": "直接发图分批数量",
                "type": "int",
                "hint": "未开启打包时，或私聊等环境，每次连发图片的最大数量；0 = 不限制数量",
                "default": 0
            },
            "video_pack_threshold": {
                "description": "排除视频合并",
                "type": "int",
                "hint": "0=视频均不打包；1=超过1个视频打包；n=超过n个视频尝试打包，<=n则独立发送防卡",
                "default": 0
            },
            "opening": {
                "description": "开场语",
                "type": "object",
                "items": {
                    "enable": {
                        "description": "发送开场语",
                        "type": "bool",
                        "default": false
                    },
                    "content": {
                        "description": "开场语内容",
                        "type": "string",
                        "default": "流媒体解析bot为您服务 ٩( 'ω' )و"
                    }
                }
            },
            "hot_comments": {
                "description": "热评设置",
                "type": "object",
                "hint": "仅对输出模式包含文本的支持平台生效",
                "items": {
                    "count": {
                        "description": "热评条数",
                        "type": "int",
                        "hint": "0 = 不获取",
                        "default": 0
                    },
                    "bilibili": {
                        "description": "B站",
                        "type": "bool",
                        "default": true
                    },
                    "weibo": {
                        "description": "微博",
                        "type": "bool",
                        "default": true
                    },
                    "xiaohongshu": {
                        "description": "小红书",
                        "type": "bool",
                        "default": true
                    }
                }
            },
            "text_format": {
                "description": "文本输出格式",
                "type": "object",
                "hint": "控制解析文本中标题、作者、简介、时间、链接等字段的显示",
                "items": {
                    "show_title": {
                        "description": "显示标题",
                        "type": "bool",
                        "default": false
                    },
                    "show_author": {
                        "description": "显示作者",
                        "type": "bool",
                        "default": true
                    },
                    "show_desc": {
                        "description": "显示简介",
                        "type": "bool",
                        "default": true
                    },
                    "show_timestamp": {
                        "description": "显示发布时间",
                        "type": "bool",
                        "default": false
                    },
                    "show_video_size": {
                        "description": "显示视频大小",
                        "type": "bool",
                        "default": false
                    },
                    "show_original_url": {
                        "description": "显示原始链接",
                        "type": "bool",
                        "default": false
                    },
                    "max_desc_length": {
                        "description": "简介最大长度",
                        "type": "int",
                        "hint": "0 = 不截断",
                        "default": 300
                    },
                    "hide_redundant_twitter_title": {
                        "description": "隐藏 Twitter/X 的冗余推文标题",
                        "type": "bool",
                        "default": true
                    },
                    "hide_duplicate_title_author": {
                        "description": "标题和作者完全相同时隐藏标题",
                        "type": "bool",
                        "default": true
                    }
                }
            }
        }
    },
    "download": {
        "description": "媒体文件缓存目录",
        "type": "object",
        "items": {
            "max_concurrent": {
                "description": "最大并发下载数",
                "type": "int",
                "hint": "建议 3~5",
                "default": 5
            },
            "cache_dir": {
                "description": "媒体文件缓存目录",
                "type": "string",
                "hint": "非 Docker 环境自动使用 AstrBot 插件数据目录；Docker 环境可配置共享挂载目录",
                "default": "/app/sharedFolder/video_parser/cache"
            },
            "max_video_size_mb": {
                "description": "视频大小上限(MB)",
                "type": "float",
                "hint": "普通视频先预检；DASH/M3U8 下载后按实际大小兜底；0 = 不限制",
                "default": 1000.0
            },
            "large_video_threshold_mb": {
                "description": "大视频阈值(MB)",
                "type": "float",
                "hint": "超过阈值单独发送，不放入消息集合，上限100MB，0 = 不限制",
                "default": 100.0
            }
        }
    },
    "permissions": {
        "description": "权限控制",
        "type": "object",
        "hint": "优先级：个人白名单 > 个人黑名单 > 群组白名单 > 群组黑名单",
        "items": {
            "admin_id": {
                "description": "管理员ID",
                "type": "string",
                "hint": "最高权限，接收私聊通知，自动加入白名单",
                "default": ""
            },
            "whitelist": {
                "description": "白名单",
                "type": "object",
                "hint": "启用但不配置名单会禁止所有用户",
                "items": {
                    "enable": {
                        "description": "启用",
                        "type": "bool",
                        "default": false
                    },
                    "user": {
                        "description": "用户",
                        "type": "list",
                        "default": []
                    },
                    "group": {
                        "description": "群组",
                        "type": "list",
                        "default": []
                    }
                }
            },
            "blacklist": {
                "description": "黑名单",
                "type": "object",
                "items": {
                    "enable": {
                        "description": "启用",
                        "type": "bool",
                        "default": false
                    },
                    "user": {
                        "description": "用户",
                        "type": "list",
                        "default": []
                    },
                    "group": {
                        "description": "群组",
                        "type": "list",
                        "default": []
                    }
                }
            }
        }
    },
    "dedup": {
        "description": "多机器人互斥",
        "type": "object",
        "items": {
            "enable": {
                "description": "启用多机器人互斥",
                "type": "bool",
                "default": false
            },
            "group": {
                "description": "启用互斥的群聊",
                "type": "list",
                "hint": "留空 = 所有群聊启用互斥；填写群号 = 仅这些群启用互斥",
                "default": []
            },
            "competitor_bot_ids": {
                "description": "互斥机器人ID",
                "type": "list",
                "hint": "填写需要避让的机器人账号ID；留空 = 不检测任何互斥机器人",
                "default": []
            },
            "wait_seconds": {
                "description": "互斥等待时间",
                "type": "float",
                "hint": "检测到可解析链接后先等待指定秒数；等待期间若互斥机器人已响应，则取消本次解析",
                "default": 3.0
            },
            "url_cooldown_seconds": {
                "description": "同链接冷却时间",
                "type": "float",
                "hint": "同一群同一链接在冷却期内只解析一次，防止本机器人重复解析；0 = 不启用",
                "default": 120.0
            },
            "ignore_competitor_messages": {
                "description": "忽略互斥机器人消息",
                "type": "bool",
                "hint": "如果消息发送者是互斥机器人ID，则直接忽略，防止两个机器人互相解析对方消息",
                "default": true
            }
        }
    },
    "bilibili_enhanced": {
        "description": "B站增强",
        "type": "object",
        "items": {
            "use_cookie": {
                "description": "携带Cookie解析",
                "type": "bool",
                "hint": "缓存目录可用时，将 DASH 视频下载到缓存目录后发送",
                "default": false
            },
            "cookie": {
                "description": "Cookie",
                "type": "string",
                "default": ""
            },
            "max_quality": {
                "description": "最高画质",
                "type": "string",
                "options": [
                    "不限制",
                    "4K",
                    "1080P60",
                    "1080P+",
                    "1080P",
                    "720P",
                    "480P",
                    "360P"
                ],
                "hint": "实际画质取决于账号权限和视频源",
                "default": "不限制"
            },
            "admin_assist": {
                "description": "管理员协助登录",
                "type": "object",
                "hint": "Cookie失效时私聊管理员协助重新登录；媒体文件缓存目录不可用时自动旁路",
                "items": {
                    "enable": {
                        "description": "启用",
                        "type": "bool",
                        "default": false
                    },
                    "reply_timeout_minutes": {
                        "description": "回复超时(分钟)",
                        "type": "int",
                        "default": 1440
                    },
                    "request_cooldown_minutes": {
                        "description": "请求冷却(分钟)",
                        "type": "int",
                        "default": 1440
                    }
                }
            }
        }
    },
    "proxy": {
        "description": "代理设置",
        "type": "object",
        "items": {
            "address": {
                "description": "代理地址",
                "type": "string",
                "hint": "格式：http://host:port 或 socks5://host:port",
                "default": ""
            },
            "tiktok": {
                "description": "TikTok解析与下载使用代理",
                "type": "bool",
                "default": false
            },
            "xiaoheihe_video": {
                "description": "小黑盒视频下载使用代理",
                "type": "bool",
                "default": true
            },
            "twitter": {
                "description": "Twitter代理",
                "type": "object",
                "items": {
                    "parse": {
                        "description": "解析",
                        "type": "bool",
                        "default": false
                    },
                    "image": {
                        "description": "图片下载",
                        "type": "bool",
                        "default": true
                    },
                    "video": {
                        "description": "视频下载",
                        "type": "bool",
                        "default": true
                    }
                }
            }
        }
    },
    "media_relay": {
        "description": "媒体中转",
        "type": "object",
        "hint": "仅增强已缓存到本地文件的媒体，不会强制下载所有媒体",
        "items": {
            "enable": {
                "description": "启用",
                "type": "bool",
                "hint": "由AstrBot HTTP服务中转缓存中的本地媒体文件",
                "default": false
            },
            "callback_url": {
                "description": "AstrBot回调地址",
                "type": "string",
                "hint": "消息平台可达的地址，如 http://host:6185，跨服务器需公网可达",
                "default": ""
            },
            "ttl": {
                "description": "中转缓存有效期(秒)",
                "type": "int",
                "hint": "到期后链接失效并清理缓存，建议 >= 60",
                "default": 300
            }
        }
    },
    "admin": {
        "description": "管理与调试",
        "type": "object",
        "items": {
            "clean_cache_keyword": {
                "description": "清理缓存关键词",
                "type": "string",
                "hint": "管理员发送此关键词清除所有媒体缓存",
                "default": "清理媒体"
            },
            "debug": {
                "description": "Debug模式",
                "type": "bool",
                "hint": "输出完整工作流详细日志",
                "default": false
            }
        }
    }
}
